STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_SCOPE=activity:read_all
# Optional one-time seed for GitHub Actions if you do not run bootstrap-appdata.
STRAVA_TOKEN_JSON_BOOTSTRAP=

# Download this OAuth desktop-client JSON from Google Cloud.
GOOGLE_CLIENT_SECRET_FILE=client_secret_google.json
# For GitHub Actions, set this as a repository secret named GOOGLE_TOKEN_JSON.
GOOGLE_TOKEN_JSON=

# Leave ID blank on first run and the tool will create the folder.
GOOGLE_DRIVE_FOLDER_NAME=Run History for ChatGPT
GOOGLE_DRIVE_FOLDER_ID=

# "true" makes readable Google Docs from Markdown summaries.
# Raw JSON files are uploaded as normal Drive files either way.
GOOGLE_UPLOAD_AS_GOOGLE_DOCS=true

# Defaults are relative to this repo.
GARMIN_DRIVE_DATA_DIR=.data
GARMIN_DRIVE_OUTPUT_DIR=run_summaries

# auto = local on your PC, Drive appDataFolder in GitHub Actions.
# Use "drive" locally when testing the same backend Actions will use.
GARMIN_DRIVE_STATE_BACKEND=auto
