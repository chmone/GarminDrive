STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_SCOPE=activity:read_all
# Comma-separated Strava sport_type values to include in history.
# Default includes runs, trail/treadmill/virtual runs, and common bike rides.
STRAVA_ACTIVITY_SPORT_TYPES=Run,TrailRun,VirtualRun,Treadmill,TrackRun,Ride,VirtualRide,MountainBikeRide,GravelRide,EBikeRide,EMountainBikeRide
# Optional one-time seed for hosted runners if you do not run bootstrap-appdata.
STRAVA_TOKEN_JSON_BOOTSTRAP=

# Download this OAuth desktop-client JSON from Google Cloud.
GOOGLE_CLIENT_SECRET_FILE=client_secret_google.json
# For Render, set this as a secret named GOOGLE_TOKEN_JSON.
GOOGLE_TOKEN_JSON=

# Leave ID blank on first run and the tool will create the folder.
GOOGLE_DRIVE_PROJECTS_FOLDER_NAME=Projects
GOOGLE_DRIVE_RUN_FOLDER_NAME=Run History
GOOGLE_DRIVE_HEALTH_FOLDER_NAME=Health Data
GOOGLE_DRIVE_PROJECTS_FOLDER_ID=
GOOGLE_DRIVE_RUN_FOLDER_ID=
GOOGLE_DRIVE_HEALTH_FOLDER_ID=
# Legacy single-folder output. Leave blank for the v1.1 Projects folder layout.
GOOGLE_DRIVE_FOLDER_NAME=
GOOGLE_DRIVE_FOLDER_ID=

# "true" makes readable Google Docs from Markdown summaries.
# Raw JSON files are uploaded as normal Drive files either way.
GOOGLE_UPLOAD_AS_GOOGLE_DOCS=true

# Defaults are relative to this repo.
GARMIN_DRIVE_DATA_DIR=.data
GARMIN_DRIVE_OUTPUT_DIR=Projects/Run History
GARMIN_DRIVE_HEALTH_OUTPUT_DIR=Projects/Health Data
GARMIN_HEALTH_TIMEZONE=America/New_York
# Optional for local first-time Garmin auth; leave unset if you prefer prompts.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# auto = local on your PC. Hosted cron jobs should set "drive".
# Use "drive" locally when testing the same backend Render will use.
GARMIN_DRIVE_STATE_BACKEND=auto

# --- Body Compass Supabase sink (optional, additive to Drive output) ---
# When DATABASE_URL is set, each sync also upserts its normalized rows into Postgres so Body Compass
# can read durable, query-ready data. Leave blank to disable (Drive publishing is unaffected).
# Use the Supabase *Session pooler* URI on IPv4-only networks / Render (the direct db.<ref> host is
# IPv6-only). URL-encode special characters in the password (e.g. '#' -> '%23').
DATABASE_URL=
# Tags every synced row with this user id (matches the app's DEFAULT_USER_ID). Single-user for now.
BODYCOMPASS_USER_ID=default
# Master switch for the sink; it also requires DATABASE_URL to be set. "false" disables it.
BODYCOMPASS_SQL_SINK=true
